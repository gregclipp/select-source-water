# ── Site configuration ─────────────────────────────────────────────
# Production URL once the custom domain is connected (no trailing slash).
# Used for canonical URLs, Open Graph, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://www.example.com

# ── Booking (Tally) ────────────────────────────────────────────────
# The form ID from your Tally form URL: https://tally.so/r/<FORM_ID>
# APPROVAL REQUIRED: create the Tally form and paste its ID here.
NEXT_PUBLIC_TALLY_FORM_ID=

# ── Contact ────────────────────────────────────────────────────────
# APPROVAL REQUIRED: business phone in E.164-ish display form.
# Leave blank to hide phone links site-wide (the site degrades gracefully).
NEXT_PUBLIC_PHONE_DISPLAY=
NEXT_PUBLIC_PHONE_TEL=
NEXT_PUBLIC_CONTACT_EMAIL=
